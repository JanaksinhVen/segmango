# Environment Configuration for Segmango SSH Project
# Copy this file to .env and fill in the values for your system

# ============= REQUIRED =============
# Project root directory (where this .env file is located)
ROOT_DIR=/home2/pronoy.patra/Segmango_project/segmango_ssh

# Data directory where images and preprocessed data are stored
DATA_DIR=/scratch/janakv

# ============= OPTIONAL =============
# Custom checkpoint directory (if not set, defaults to ROOT_DIR/checkpoints/folds)
# CHECKPOINT_DIR=/custom/path/to/checkpoints

# Custom results directory for plots (if not set, defaults to ROOT_DIR/results)
# RESULTS_DIR=/custom/path/to/results

# Preferred CUDA device index (if not set, uses default device)
# CUDA_DEVICE=0

# Number of worker processes for data loading (default: 4)
NUM_WORKERS=4

# Random seed for reproducibility (default: 42)
RANDOM_SEED=42
